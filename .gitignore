## Standard .NET / C# .gitignore

# Build outputs
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# User-specific files
*.rsuser
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/
*.suo

# JetBrains Rider
.idea/
*.sln.iml

# NuGet packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# MSBuild outputs
project.lock.json
project.fragment.lock.json
artifacts/

# Publish output
publish/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Installer build output
installer/Output/
installer/*.exe

# OS files
Thumbs.db
.DS_Store
Desktop.ini
